# Copy this file to `.env` and fill in values (local dev and many hosts load `.env`).

# GoHighLevel — Private Integration token (must be pit-… from the SAME sub-account as GHL_LOCATION_ID)
# Prefer: open the Location → Settings → Private Integrations (not agency-only), scopes: contacts.readonly + contacts.write
# Paste only the token — no "Bearer " prefix, no quotes
GHL_API_TOKEN=

# Sub-account location ID (often visible in the GHL URL or location settings)
GHL_LOCATION_ID=

# Optional — API version header (default: 2023-02-21). If you get CRM errors, try 2021-07-28
# GHL_API_VERSION=2021-07-28

# Optional — set to 1 to skip tags on the GHL payload (use if CRM rejects unknown tag names)
# GHL_NO_TAGS=1

# Optional — comma-separated tags on the new contact (default: Website,Buyer Form)
# GHL_BUYER_TAGS=Website,Buyer Form

# Optional — contact "source" (default: Website — Buyer Form)
# GHL_BUYER_SOURCE=Website — Buyer Form

# Optional — seller / home value form tags & source (defaults: Website, Seller Form | Website — Home Value / Sell)
# GHL_SELLER_TAGS=Website,Seller Form
# GHL_SELLER_SOURCE=Website — Home Value / Sell

# Optional — investment form tags & source (defaults: Website, Investment Form | Website — Investment)
# GHL_INVESTMENT_TAGS=Website,Investment Form
# GHL_INVESTMENT_SOURCE=Website — Investment

# Optional — commercial form tags & source (defaults: Website, Commercial Form | Website — Commercial)
# GHL_COMMERCIAL_TAGS=Website,Commercial Form
# GHL_COMMERCIAL_SOURCE=Website — Commercial

# Optional — /join network form tags & source (defaults: Website, Join Network | Website — Join Network)
# GHL_JOIN_TAGS=Website,Join Network
# GHL_JOIN_SOURCE=Website — Join Network

# Optional — /contact form tags & source (defaults: Website, Contact Form | Website — Contact)
# GHL_CONTACT_TAGS=Website,Contact Form
# GHL_CONTACT_SOURCE=Website — Contact
